# ===== アプリ =====
# ENVIRONMENT は local 環境の配備モードを兼ねる:
#   development(既定) → サービス管理画面の起動/停止: 前処理は uv 管理の Python プロセス、
#                        Parser(重い ML 依存)は docker compose(docker-compose.dev.yml で
#                        ポート公開)で行う(制御は自動有効。Parser は事前イメージ build を推奨)。
#   production         → 起動/停止は docker compose で行う(別途 RAG_SERVICE_CONTROL_ENABLED=true が必要)。
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0
AI_SERVICE_ADAPTER=local
MODEL_SETTINGS_FILE=model-settings.json
CORS_ORIGINS=["http://localhost:3000"]

# ===== 認証 =====
# local ではログイン/ログアウトを表示・要求しない。production では Cookie セッション認証を要求する。
AUTH_MODE=local
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
AUTH_SESSION_TIMEOUT_SECONDS=86400
AUTH_COOKIE_NAME=production_ready_rag_session
AUTH_COOKIE_SECURE=false

# ===== OCI 共通 =====
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=ap-osaka-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxx

# ===== OCI Enterprise AI（LLM / VLM）=====
# 注意: OCI Generative AI の chat 推論 API ではなく Enterprise AI を使う
OCI_ENTERPRISE_AI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1
OCI_ENTERPRISE_AI_PROJECT_OCID=ocid1.generativeaiproject.oc1.us-chicago-1.xxxxxxxx
# API key 認証を使う場合のみ設定する。OCI 署名/IAM 認証では空欄のまま。
OCI_ENTERPRISE_AI_API_KEY=
OCI_ENTERPRISE_AI_LLM_MODEL=
OCI_ENTERPRISE_AI_VLM_MODEL=
OCI_ENTERPRISE_AI_LLM_PATH=/responses
OCI_ENTERPRISE_AI_VLM_PATH=/responses
# endpoint の request shape が標準 payload と異なる場合のみ JSON object template を設定する。
# string placeholder: ${model}, ${compartment_id}, ${prompt}, ${context}, ${user_message}, ${system_prompt}, ${mime_type}, ${data_base64}
# object placeholder: "${messages}", "${parameters}", "${response_format}", "${structured_extraction_schema}"
OCI_ENTERPRISE_AI_LLM_PAYLOAD_TEMPLATE=
OCI_ENTERPRISE_AI_VLM_PAYLOAD_TEMPLATE=
# response が独自 envelope の場合だけ JSON Pointer で候補 node を指定する。
# 例: /payload/results/0/generated/text, /payload/results/0/document
OCI_ENTERPRISE_AI_LLM_RESPONSE_PATH=
OCI_ENTERPRISE_AI_VLM_RESPONSE_PATH=
OCI_ENTERPRISE_AI_TIMEOUT_SECONDS=600
OCI_ENTERPRISE_AI_MAX_RETRIES=3
OCI_ENTERPRISE_AI_LLM_MAX_OUTPUT_TOKENS=1200
OCI_ENTERPRISE_AI_VLM_MAX_OUTPUT_TOKENS=65536
OCI_ENTERPRISE_AI_SIGN_REQUESTS=true

# ===== OCI Generative AI（埋め込み / リランク）=====
OCI_GENAI_EMBEDDING_MODEL=cohere.embed-v4.0
OCI_GENAI_EMBEDDING_DIM=1536
OCI_GENAI_RERANK_MODEL=cohere.rerank-v4.0-fast

# ===== Oracle 26ai =====
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_CLIENT_LIB_DIR=/u01/aipoc/instantclient_23_26
# Wallet は ORACLE_CLIENT_LIB_DIR/network/admin に固定配置します。
ORACLE_WALLET_PASSWORD=
# Autonomous Database 管理（起動 / 停止 / 情報取得）の操作対象 OCID。OCI_REGION と組で使用。
ORACLE_ADB_OCID=
ORACLE_SELECT_AI_PROFILE=
ORACLE_SELECT_AI_MAX_RESULT_CHARS=20000
ORACLE_VECTOR_TARGET_ACCURACY=95

# ===== OCI Object Storage =====
# アップロード原本の保存先。local は LOCAL_STORAGE_DIR、oci は OCI Object Storage。
UPLOAD_STORAGE_BACKEND=local
OBJECT_STORAGE_REGION=ap-osaka-1
OBJECT_STORAGE_NAMESPACE=
OBJECT_STORAGE_BUCKET=

# ===== ローカル参照実装 =====
LOCAL_STORAGE_DIR=/u01/production-ready-rag
MAX_UPLOAD_BYTES=209715200
ALLOWED_UPLOAD_CONTENT_TYPES=["application/pdf","image/jpeg","image/png","image/tiff","text/plain","application/octet-stream"]

# ===== 取込 queue =====
INGESTION_QUEUE_STARTUP_RECOVERY_ENABLED=true
INGESTION_QUEUE_STARTUP_DRAIN_LIMIT=50
INGESTION_QUEUE_STALE_RUNNING_SECONDS=3600
INGESTION_QUEUE_RECOVERY_INTERVAL_SECONDS=60
INGESTION_QUEUE_WORKER_CONCURRENCY=2
INGESTION_JOB_MAX_ATTEMPTS=3
# HTTP リクエストは取込 job を投入するだけにし、取込本体は worker が消費します。
INGESTION_QUEUE_DEDICATED_WORKER_ENABLED=true
# ローカル開発では API process 内 dispatcher を起動し、job 本体は subprocess へ隔離します。
INGESTION_QUEUE_INPROCESS_WORKER_ENABLED=true
INGESTION_QUEUE_PROCESS_ISOLATION_ENABLED=true

# ===== RAG =====
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_MAX_CHUNKS_PER_DOCUMENT=512
RAG_CONTEXT_WINDOW_CHARS=12000
RAG_CONTEXT_NEIGHBOR_WINDOW=0
RAG_CONTEXT_DIVERSITY_LAMBDA=1.0
RAG_CONTEXT_COMPRESSION_ENABLED=false
RAG_CONTEXT_COMPRESSION_MAX_SENTENCES=3
RAG_CONTEXT_COMPRESSION_MAX_CHARS_PER_CHUNK=1200
RAG_MIN_SIMILARITY=0.05
RAG_RRF_K=60
RAG_QUERY_EXPANSION_ENABLED=true
RAG_QUERY_EXPANSION_MAX_VARIANTS=3
RAG_SEARCH_TIMEOUT_SECONDS=30
RAG_PDF_SEGMENTATION_ENABLED=true
RAG_PDF_MAX_PAGES_PER_SEGMENT=10
RAG_PDF_MAX_SEGMENTS=300
# 2 段階処理(parse → 人がプレビュー確認 → index)。true で抽出後 REVIEW で停止し、
# 承認 API 経由で索引する。false(既定)は従来どおり 1 ジョブで INDEXED まで一気通貫。
RAG_REVIEW_GATE_ENABLED=false

# ===== 前処理マイクロサービス(parse 前の原本変換)=====
# 1 変換 = 1 独立サービス。RAG_PREPROCESS_PROFILE で選択し、委譲は RAG_PREPROCESS_ENABLED で有効化。
# 未達/失敗時は warning を付けて passthrough(原本そのまま parse)へ安全に縮退する。
# URL は docker 名(prod 用)。dev(ENVIRONMENT=development)では backend が catalog の dev_port
# (127.0.0.1:8010-8013)へ自動で問い合わせるため、この URL の編集は不要。
RAG_PREPROCESS_ENABLED=true
RAG_PREPROCESS_OFFICE_TO_PDF_SERVICE_URL=http://preprocess-office-to-pdf:8000
RAG_PREPROCESS_PDF_TO_PAGE_IMAGES_SERVICE_URL=http://preprocess-pdf-to-page-images:8000
RAG_PREPROCESS_CSV_TO_JSON_SERVICE_URL=http://preprocess-csv-to-json:8000
RAG_PREPROCESS_EXCEL_TO_JSON_SERVICE_URL=http://preprocess-excel-to-json:8000
RAG_PREPROCESS_SERVICE_TIMEOUT_SECONDS=300

# ===== サービス管理(起動/停止)=====
# サービス管理画面の起動/停止は配備モードで分岐する:
#   dev(ENVIRONMENT=development) → uv 管理のローカル Python プロセス(制御は自動有効。下記フラグ不要)。
#   prod(ENVIRONMENT=production) → docker compose 制御。明示的に RAG_SERVICE_CONTROL_ENABLED=true が必要で、
#                                  backend が docker CLI を実行できること(docker.sock + CLI のマウント等)。
RAG_SERVICE_CONTROL_ENABLED=false
RAG_SERVICE_CONTROL_COMMAND=docker compose
RAG_SERVICE_CONTROL_TIMEOUT_SECONDS=60
RAG_SERVICE_STATUS_PROBE_TIMEOUT_SECONDS=2

# ===== Parser マイクロサービス =====
# 外部 parser(docling/marker/unstructured/mineru/dots_ocr)は独立 FastAPI サービスで動き、
# backend は取込時に HTTP 委譲する(未達時は local / Enterprise AI VLM へ fallback)。
# 各 parser の有効化は従来どおり RAG_PARSER_ADAPTER_BACKEND と RAG_PARSER_<name>_ENABLED で行う。
RAG_PARSER_DOCLING_SERVICE_URL=http://parser-docling:8000
RAG_PARSER_MARKER_SERVICE_URL=http://parser-marker:8000
RAG_PARSER_UNSTRUCTURED_SERVICE_URL=http://parser-unstructured:8000
RAG_PARSER_MINERU_SERVICE_URL=http://parser-mineru:8000
RAG_PARSER_DOTS_OCR_SERVICE_URL=http://parser-dots-ocr:8000
RAG_PARSER_SERVICE_TIMEOUT_SECONDS=300
# readiness 画面の version/可用性を parser サービスの /health で表示する(compose/本番で true)。
RAG_PARSER_READINESS_PROBE_ENABLED=false
RAG_PARSER_READINESS_PROBE_TIMEOUT_SECONDS=2

# ===== service 系 parser backend(OCI クラウドサービス直呼び)=====
# RAG_PARSER_ADAPTER_BACKEND=enterprise_ai_vlm を選ぶと、fallback ではなく明示的に
# OCI Enterprise AI VLM で OCR/抽出する(別 env は不要、Enterprise AI 設定を再利用)。
#
# RAG_PARSER_ADAPTER_BACKEND=oci_document_understanding を選ぶと、別 OCI サービス
# OCI Document Understanding(oci.ai_document)の非同期 processor job で日本語 OCR/表抽出する。
# 入出力は Object Storage 経由。未設定/失敗時は安全に local / Enterprise AI VLM へ縮退する。
# compartment / namespace / 入力 bucket が空なら、それぞれ汎用の OCI_COMPARTMENT_ID /
# OBJECT_STORAGE_NAMESPACE / OBJECT_STORAGE_BUCKET を使う。
OCI_DOCUMENT_UNDERSTANDING_COMPARTMENT_ID=
OCI_DOCUMENT_UNDERSTANDING_NAMESPACE=
OCI_DOCUMENT_UNDERSTANDING_INPUT_BUCKET=
OCI_DOCUMENT_UNDERSTANDING_OUTPUT_BUCKET=
OCI_DOCUMENT_UNDERSTANDING_INPUT_PREFIX=document-understanding/input
OCI_DOCUMENT_UNDERSTANDING_OUTPUT_PREFIX=document-understanding/output
OCI_DOCUMENT_UNDERSTANDING_LANGUAGE=JPN
OCI_DOCUMENT_UNDERSTANDING_POLL_INTERVAL_SECONDS=5
OCI_DOCUMENT_UNDERSTANDING_TIMEOUT_SECONDS=600

# ===== ガードレール =====
GUARDRAIL_MAX_QUERY_CHARS=2000
GUARDRAIL_BLOCK_PROMPT_INJECTION=true

# ===== 監査 =====
# tenant/user id header を監査ログへ hash 化するときの任意 salt。Production では OCI Vault から注入する。
AUDIT_CONTEXT_HASH_SALT=

# ===== Trace export =====
# OpenTelemetry / Langfuse 連携用 gateway へ脱機密化済み trace span event を非同期 POST する。
# 空なら構造化ログ + Prometheus のみ。
TRACE_EXPORT_HTTP_ENDPOINT=
TRACE_EXPORT_HTTP_BEARER_TOKEN=
TRACE_EXPORT_TIMEOUT_SECONDS=2
TRACE_EXPORT_QUEUE_SIZE=1024
