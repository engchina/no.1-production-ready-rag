# ===== アプリ =====
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0
AI_SERVICE_ADAPTER=local
CORS_ORIGINS=["http://localhost:3000"]

# ===== 認証 =====
# local ではログイン/ログアウトを表示・要求しない。production では Cookie セッション認証を要求する。
AUTH_MODE=local
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
AUTH_SESSION_TIMEOUT_SECONDS=86400
AUTH_COOKIE_NAME=production_ready_rag_session
AUTH_COOKIE_SECURE=false

# ===== OCI 共通 =====
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=ap-osaka-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxx

# ===== OCI Enterprise AI（LLM / VLM）=====
# 注意: OCI Generative AI の chat 推論 API ではなく Enterprise AI を使う
OCI_ENTERPRISE_AI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1
OCI_ENTERPRISE_AI_PROJECT_OCID=ocid1.generativeaiproject.oc1.us-chicago-1.xxxxxxxx
# API key 認証を使う場合のみ設定する。OCI 署名/IAM 認証では空欄のまま。
OCI_ENTERPRISE_AI_API_KEY=
OCI_ENTERPRISE_AI_LLM_MODEL=
OCI_ENTERPRISE_AI_VLM_MODEL=
OCI_ENTERPRISE_AI_LLM_PATH=/responses
OCI_ENTERPRISE_AI_VLM_PATH=/responses
# endpoint の request shape が標準 payload と異なる場合のみ JSON object template を設定する。
# string placeholder: ${model}, ${compartment_id}, ${prompt}, ${context}, ${user_message}, ${system_prompt}, ${mime_type}, ${data_base64}
# object placeholder: "${messages}", "${parameters}", "${response_format}", "${structured_extraction_schema}"
OCI_ENTERPRISE_AI_LLM_PAYLOAD_TEMPLATE=
OCI_ENTERPRISE_AI_VLM_PAYLOAD_TEMPLATE=
# response が独自 envelope の場合だけ JSON Pointer で候補 node を指定する。
# 例: /payload/results/0/generated/text, /payload/results/0/document
OCI_ENTERPRISE_AI_LLM_RESPONSE_PATH=
OCI_ENTERPRISE_AI_VLM_RESPONSE_PATH=
OCI_ENTERPRISE_AI_TIMEOUT_SECONDS=60
OCI_ENTERPRISE_AI_MAX_RETRIES=2
OCI_ENTERPRISE_AI_SIGN_REQUESTS=true

# ===== OCI Generative AI（埋め込み / リランク）=====
OCI_GENAI_EMBEDDING_MODEL=cohere.embed-v4.0
OCI_GENAI_EMBEDDING_DIM=1536
OCI_GENAI_RERANK_MODEL=cohere.rerank-v4.0-fast

# ===== Oracle 26ai =====
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_CLIENT_LIB_DIR=/u01/aipoc/instantclient_23_26
# Wallet は ORACLE_CLIENT_LIB_DIR/network/admin に固定配置します。
ORACLE_WALLET_PASSWORD=
ORACLE_SELECT_AI_PROFILE=
ORACLE_SELECT_AI_MAX_RESULT_CHARS=20000
ORACLE_VECTOR_TARGET_ACCURACY=95

# ===== OCI Object Storage =====
# アップロード原本の保存先。local は LOCAL_STORAGE_DIR、oci は OCI Object Storage。
UPLOAD_STORAGE_BACKEND=local
OBJECT_STORAGE_REGION=ap-osaka-1
OBJECT_STORAGE_NAMESPACE=
OBJECT_STORAGE_BUCKET=

# ===== ローカル参照実装 =====
LOCAL_STORAGE_DIR=/tmp/production-ready-rag
MAX_UPLOAD_BYTES=209715200
ALLOWED_UPLOAD_CONTENT_TYPES=["application/pdf","image/jpeg","image/png","image/tiff","text/plain","application/octet-stream"]

# ===== RAG =====
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_MAX_CHUNKS_PER_DOCUMENT=512
RAG_CONTEXT_WINDOW_CHARS=12000
RAG_CONTEXT_NEIGHBOR_WINDOW=0
RAG_CONTEXT_DIVERSITY_LAMBDA=1.0
RAG_CONTEXT_COMPRESSION_ENABLED=false
RAG_CONTEXT_COMPRESSION_MAX_SENTENCES=3
RAG_CONTEXT_COMPRESSION_MAX_CHARS_PER_CHUNK=1200
RAG_MIN_SIMILARITY=0.05
RAG_RRF_K=60
RAG_QUERY_EXPANSION_ENABLED=true
RAG_QUERY_EXPANSION_MAX_VARIANTS=3
RAG_SEARCH_TIMEOUT_SECONDS=30

# ===== ガードレール =====
GUARDRAIL_MAX_QUERY_CHARS=2000
GUARDRAIL_BLOCK_PROMPT_INJECTION=true

# ===== 監査 =====
# tenant/user id header を監査ログへ hash 化するときの任意 salt。Production では OCI Vault から注入する。
AUDIT_CONTEXT_HASH_SALT=

# ===== Trace export =====
# OpenTelemetry / Langfuse 連携用 gateway へ脱機密化済み trace span event を非同期 POST する。
# 空なら構造化ログ + Prometheus のみ。
TRACE_EXPORT_HTTP_ENDPOINT=
TRACE_EXPORT_HTTP_BEARER_TOKEN=
TRACE_EXPORT_TIMEOUT_SECONDS=2
TRACE_EXPORT_QUEUE_SIZE=1024
